# ── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ── Input connector: where conversations come from ─────────────────────────
# "demo" serves a built-in synthetic conversation (no backend) — ANNOTATE_INPUT=demo
# "modal" pulls from the upstream Modal FastAPI service.
ANNOTATE_INPUT=modal
ANNOTATE_MODAL_BASE_URL=https://<your-workspace>--<your-app>.modal.run
ANNOTATE_MODAL_COOKIE=annotation_auth=PUT_TOKEN_HERE
ANNOTATE_MAX_CONVERSATIONS=1000
# Optional: restrict to specific Modal volumes (comma-separated).
# ANNOTATE_MODAL_VOLUMES=volume-a,volume-b

# ── Output connector: where annotations are saved ──────────────────────────
# "gdrive" saves to Google Drive; "local" saves to ANNOTATE_OUTPUT_DIR.
ANNOTATE_OUTPUT=gdrive
ANNOTATE_OUTPUT_DIR=./annotations

# Google Drive output target folder.
ANNOTATE_GDRIVE_FOLDER_ID=

# Drive auth, option A — OAuth refresh token (run `bun run oauth-setup`):
ANNOTATE_GDRIVE_OAUTH_CLIENT_ID=
ANNOTATE_GDRIVE_OAUTH_CLIENT_SECRET=
ANNOTATE_GDRIVE_OAUTH_REFRESH_TOKEN=
